/*
 * resources.config — Slurm / HPC resource labels for T2T-Polish Nextflow pipeline
 *
 * This file contains the process executor settings and per-label resource
 * allocations.  It is intentionally kept separate from user.config so that
 * cluster-specific settings can be adjusted (or replaced entirely) without
 * touching the user's path/glob config.
 *
 * HOW TO CUSTOMISE
 * ----------------
 * Copy this file and point Nextflow at your copy:
 *
 *   nextflow run main.nf -c user.config -c my_resources.config
 *
 * Or include it explicitly inside your user.config:
 *
 *   includeConfig '/path/to/my_resources.config'
 *
 * The labels below map to the resource budgets that the original
 * Biowulf _submit scripts used.  Adjust cpus / memory / time / queue /
 * clusterOptions to match your job-submission system.
 *
 * For non-Slurm schedulers, change `executor = 'slurm'` to the appropriate
 * Nextflow executor name (e.g. 'sge', 'lsf', 'pbspro', 'local', …).
 * See https://www.nextflow.io/docs/latest/executor.html
 */

executor {
  name      = 'slurm'
  queueSize = 500   // max jobs Nextflow will have queued/running at once
  submitRateLimit = '10/1sec'  // submit up to 10 jobs per second (avoid scheduler floods)
  // GPFS/Lustre read-after-write latency: wait longer for .exitcode to become
  // visible before declaring a job "terminated for an unknown reason".
  // Default is 270s; bump to 10min for shared-FS scratch like Biowulf /vf/.
  exitReadTimeout = '10 min'
}

process {
  executor      = 'slurm'
  errorStrategy = 'retry'   // on failure: retry once
  maxRetries    = '1'

  // Fallback defaults (used when no withLabel block matches)
  cpus   = 12
  memory = '12 GB'
  time   = '4h'
  queue  = 'quick'

  // k8 / BWA index (quick partition, small footprint)
  withLabel: 'quick_small' {
    queue  = 'quick'
    cpus   = 4
    memory = '10 GB'
    time   = '4h'
  }

  // Meryl repetitive-kmer counting (quick partition)
  withLabel: 'quick_meryl' {
    queue  = 'quick'
    cpus   = 12
    memory = '24 GB'
    time   = '30m'
  }

  // Winnowmap read mapping (large memory + local scratch)
  withLabel: 'norm_map' {
    queue  = 'norm'
    cpus   = 24
    memory = '60 GB'
    time   = '2d'
    clusterOptions = '--gres=lscratch:900'
  }

  // BWA read mapping (large memory + local scratch)
  withLabel: 'norm_bwa_map' {
    queue  = 'norm'
    cpus   = 24
    memory = '48 GB'
    time   = '5d'
    clusterOptions = '--gres=lscratch:1000'
  }

  // Winnowmap BAM merge
  withLabel: 'merge_wm' {
    queue  = 'quick'
    cpus   = 48
    memory = '12 GB'
    time   = '4h'
  }

  // BWA BAM merge
  withLabel: 'merge_bwa' {
    queue  = 'quick'
    cpus   = 24
    memory = '12 GB'
    time   = '4h'
  }

  // BAM filtering and SAM→PAF conversion
  withLabel: 'filter_bam' {
    queue  = 'quick'
    cpus   = 12
    memory = '8 GB'
    time   = '4h'
  }

  // Reference building / concat
  withLabel: 'build_ref' {
    queue  = 'quick'
    cpus   = 4
    memory = '16 GB'
    time   = '2h'
  }

  // Hybrid BAM merge (HiFi + Illumina/Element)
  withLabel: 'merge_hybrid' {
    queue  = 'quick'
    cpus   = 12
    memory = '24 GB'
    time   = '4h'
  }

  // DeepVariant step 1: make_examples (CPU scatter with GNU parallel)
  withLabel: 'dv_make_examples' {
    queue          = 'norm'
    cpus           = 12          // matches dv_n_shard default
    memory         = '48 GB'     // ~4g per shard
    time           = '10d'
    clusterOptions = '--gres=lscratch:1000'
  }

  // DeepVariant step 2: call_variants (GPU)
  withLabel: 'dv_call_variants' {
    queue          = 'gpu'
    cpus           = 12
    memory         = '48 GB'
    time           = '12h'
    clusterOptions = '--gres=gpu:1'
    maxRetries     = 1           // retry once on zero-size output
  }

  // DeepVariant step 3: postprocess_variants (CPU)
  withLabel: 'dv_postprocess' {
    queue  = 'norm'
    cpus   = 12
    memory = '160 GB'
    time   = '12h'
  }

  // ONT R9: pepper_margin_deepvariant per-chromosome scatter (GPU)
  // Matches the resources used in _submit_ont_r9_pepper_margin_dv.sh
  withLabel: 'dv_pepper_margin' {
    queue          = 'gpu'
    cpus           = 12
    memory         = '48 GB'
    time           = '2h'
    clusterOptions = '--gres=gpu:1,lscratch:10'
  }

  // SNV candidates: bcftools reheader / filter / isec steps (light)
  withLabel: 'snv_filter' {
    queue  = 'quick'
    cpus   = 12
    memory = '12 GB'
    time   = '1h'
  }

  // SNV candidates: Merfin -strict / -loose (high-memory; meryl DB lookup)
  withLabel: 'snv_merfin' {
    queue  = 'norm'
    cpus   = 12
    memory = '120 GB'
    time   = '12h'
  }

  // Evaluation
  withLabel: 'evaluation' {
    queue  = 'quick'
    cpus   = 12
    memory = '24 GB'
    time   = { 1.h * task.attempt }   // 1h on first try, 2h on retry
  }
}
