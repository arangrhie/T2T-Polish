/*
 *
 * Create a user config (recommended):
 *   nextflow run main.nf -c user.config
 */

nextflow.enable.dsl=2

params {
  outdir        = 'results'
  // asm_name and asm_ver together form the filename prefix throughout (BAMs, VCFs,
  // reference files): {asm_name}_{asm_ver}.{hap}.{platform}.*
  // e.g. asm_name = 'bTaeGut7', asm_ver = 'v0.1' → prefix 'bTaeGut7_v0.1'
  asm_name      = 'assembly'
  asm_ver       = 'v0.1'
  platforms     = 'hifi,ont,illumina' // replace illumina with element if available

  // Reference pieces (set these in your user config)
  hap1_fasta_gz = null
  hap2_fasta_gz = null
  mito_exemplar_fasta_gz = null
  rdna_exemplar_fasta_gz = null
  ebv_fasta_gz  = null

  // Pre-built reference FA.GZ re-entry (Round 1 only).
  // If set, BUILD_HAP_REFERENCES and BUILD_DIP_REFERENCE are skipped.
  // Point to the assemblies/ output directory; filenames are inferred as
  //   {asm_name}_{asm_ver}.{hap1,hap2,dip}.fa.gz  (+ .gzi and .fai alongside).
  // e.g. '/path/to/results/assemblies'
  assemblies_dir = null

  // Read globs (set these in your user config)
  read_glob_hifi     = null
  read_glob_ont      = null
  read_glob_illumina = null
  read_glob_element  = null

  samtools = 'samtools'

  mapping_outdir = "${outdir}/mapping"

  // Path to k8 binary for sam2paf (paftools.js), e.g. /path/to/tools/k8/k8
  k8 = 'k8'

  // Set to true to keep per-read (Winnowmap) and per-pair (BWA) intermediate
  // BAMs in the results directory after the merged BAM has been created.
  // Default: false — intermediates are kept only in the Nextflow work/ cache.
  keep_intermediates = false

  // ONT mapping scope: by default ONT reads are mapped only to the dip
  // reference (required for DeepVariant Track B).  Set to true to also map
  // ONT reads to hap1 and hap2.
  ont_map_haps = false

  // ---- Re-entry / skip options --------------------------------------------
  // Set these in your user config to skip stages whose outputs already exist
  // in the results directory (e.g. after a failed run).  Leave null to run
  // all stages normally.
  //
  // Use LITERAL paths — cross-file params.* references in GStrings are not
  // resolved at parse time and will cause "Unknown config attribute" errors.
  //
  // mapping_dir    — point to the mapping/ output directory.
  //   Winnowmap pri BAMs, BWA BAMs, and hybrid merged BAMs are all discovered
  //   automatically using the {asm_name}_{asm_ver} filename prefix.
  //   Skips WM mapping, BWA mapping, and MERGE_HYBRID (per hap) as available.
  //   e.g. '/path/to/results/mapping'
  //
  // deepvariant_dir — point to the deepvariant/ output directory.
  //   DV examples/ dirs are discovered automatically.
  //   Skips DV make_examples (step 1) per hap/combo as available.
  //   e.g. '/path/to/results/deepvariant'
  mapping_dir     = null
  deepvariant_dir = null

  // ---- Pipeline mode -------------------------------------------------------------------------------
  // evaluate = true: skip DeepVariant/SNV polishing and run post-mapping evaluation only.
  // evaluate = false (default): run full polishing workflow.
  evaluate              = false

  // ---- DeepVariant (active when evaluate = false) --------------------------------------------------
  dv_mq_hap             = 5      // MQ filter for hap1/hap2 merged BAMs
  dv_mq_dip             = 0      // MQ filter for dip   merged BAMs
  ont_chemistry         = 'r10'  // ONT chemistry: 'r10' (DeepVariant ONT_R104) or 'r9' (PEPPER-Margin-DV).
  dv_outdir             = "${outdir}/deepvariant"
  dv_sample             = null   // sample name in VCF; defaults to hap tag if null
  dv_n_shard            = 12     // number of make_examples shards (= CPUs for step 1)
  dv_long_platforms     = 'hifi'             // long-read platform(s) for hybrid merge
  dv_short_platforms    = 'illumina,element' // short-read platform(s) for hybrid merge

  // ---- SNV candidates (on by default; disable with run_snv_candidates = false) ---
  // Requires run_dv_ont = true for the ONT track.
  run_snv_candidates    = true
  snv_outdir            = "${outdir}/snv_candidates"
  hybrid_meryl          = null   // path to hybrid read k-mer meryl DB (required)
  merfin_peak           = null   // integer peak coverage for Merfin (required)
  tools                 = null   // path to the tools root directory (e.g. '/data/Phillippy/tools')
  merfin                = null   // path/command to merfin binary; defaults to "${tools}/merfin/1.1/bin/merfin" if tools is set, else 'merfin'
  asm_ver_next          = null   // next polished version tag (e.g. 'v0.2'); auto-bumped from asm_ver if null
  keep_snv_intermediates = false // publish intermediate VCFs from SNV_FILTER_INTERSECT
  // Number of SNV polishing rounds to run (1–5). Default: 2.
  // Each round maps all reads to the polished assembly from the previous round,
  // calls variants with DeepVariant, and applies Merfin-validated SNVs.
  // Only active when run_snv_candidates = true.
  polish_rounds         = 2
}

// Resource labels and executor settings live in resources.config so users
// can swap in a site-specific version without touching this file.
includeConfig 'resources.config'
